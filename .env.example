# ────────────────────────────────────────────────────
# 실제 배포 시 이 파일을 복사하여 .env 로 저장하세요.
#   cp .env.example .env
# .env 는 절대 git 에 커밋하지 마세요!
# ────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=변경하세요_강력한패스워드
MYSQL_DATABASE=selfdev
MYSQL_USER=selfdev
MYSQL_PASSWORD=변경하세요_강력한패스워드

# Spring Boot DataSource
SPRING_DATASOURCE_USERNAME=selfdev
SPRING_DATASOURCE_PASSWORD=변경하세요_강력한패스워드

# JWT — 최소 64자의 무작위 문자열 (아래 명령으로 생성)
#   openssl rand -base64 64
JWT_SECRET=여기에_openssl_rand_-base64_64_출력값_붙여넣기
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000
